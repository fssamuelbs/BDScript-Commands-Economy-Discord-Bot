$image[https://api.popcat.xyz/ship?user1=$authorAvatar&user2=$userAvatar[$splitText[4]]]

$setVar[casado;Casado(a) com $username[$splitText[4]];$authorID]
$setVar[casado;Casado(a) com $username[$authorID];$splitText[4]]
$setVar[casadoID;$authorID;$splitText[4]]
$setVar[casadoID;$splitText[4];$authorID]
$color[c917ff]
$setVar[Alianca;$sub[$getVar[Alianca;$splitText[4]];2];$splitText[4]]
$setVar[saberseecasado;$sum[$getVar[saberseecasado;$authorID];2];$authorID]
$setVar[saberseecasado;$sum[$getVar[saberseecasado;$splitText[4]];2];$splitText[4]]


$endif

