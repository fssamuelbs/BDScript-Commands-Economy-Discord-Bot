$if[$and[$textSplit[$customID;-]$splitText[2]==casar;$splitText[3]==$authorID]==true]
$cooldown[30s;]
<@$authorID> | <@$splitText[4]>
$onlyIf[$getVar[Registrado;$splitText[4]]>1;<:fx_uncertification:1123653285451153508> **|** <@$authorID> deve se registrar em meu sistema antes de usar meus comandos, use ``/registrar``]
$onlyIf[$getVar[casado;$splitText[4]]==Solteiro (a);<:fx_uncertification:1123653285451153508> **|** <@$splitText[4]> já está casado! não pode trair viu, é feio!]
